{
  "manifest_version": 2,
  "name": "KLR Kostenstelle Filter",
  "version": "1.0",
  "description": "Adds a live-filter combobox to any dropdown with more than 10 options on reisekosten.zi.local",
  "browser_specific_settings": {
    "gecko": {
      "id": "psg-filter@reisekosten.zi.local",
      "strict_min_version": "57.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://reisekosten.zi.local/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
